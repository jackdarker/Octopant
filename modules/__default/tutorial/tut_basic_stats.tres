script = ExtResource("1_sq46a")
ID = "basic_stats"
title = "Your stats"
text = "There are those major stats:
[b]Pain[/b]: increases if you get hurt and if it reaches max you passout
[b]Fatigue[/b]: increases if you explore or work; if it reaches max you cannot continue
All of the stats usually regenerate if you rest or sleep."
